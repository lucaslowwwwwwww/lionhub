rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helper: Check if user is Master ───
    function isMaster() {
      return request.auth != null && request.auth.token.email == 'chuancheng2020@gmail.com';
    }

    // ─── Helper: Check if user is an Admin ───
    function isAdmin() {
      return isMaster() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        (!('status' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'deleted')
      );
    }

    // ─── Helper: Check if user is logged in ───
    function isSignedIn() {
      return request.auth != null;
    }

    // ─── Global Settings ───
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Users Collection ───
    // SECURITY: Users can update their OWN profile (name, phone), but CANNOT change their role.
    // Only Masters can change roles or create/delete user documents.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isMaster();
      allow update: if isMaster() 
                    || (request.auth.uid == userId 
                        && request.resource.data.get('role', '') == resource.data.get('role', '')
                        && request.resource.data.get('status', '') == resource.data.get('status', ''));
    }

    // ─── Members Collection (Troupe Personnel) ───
    match /members/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Customers Collection ───
    match /customers/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Finance Collection ───
    // Schema validation: amount must be a number, type must be income/expense/sponsorship, date must be a string.
    match /finance/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.amount is number
                    && request.resource.data.type in ['income', 'expense', 'sponsorship']
                    && request.resource.data.date is string;
      allow update: if isAdmin()
                    && request.resource.data.amount is number
                    && request.resource.data.type in ['income', 'expense', 'sponsorship']
                    && request.resource.data.date is string;
      allow delete: if isAdmin();
    }

    // ─── Audit Logs (Immutable) ───
    // Any signed-in user can create logs, but NOBODY (not even admins) can edit or delete them.
    match /audit_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ─── Troupes Collection ───
    match /troupes/{troupeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Inventory Collection ───
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Itineraries Collection ───
    match /itineraries/{itinId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      // Nested Stops subcollection
      match /stops/{stopId} {
        allow read: if isSignedIn();
        allow update: if isSignedIn()
                      && (isAdmin() || (
                        // Standard members can ONLY complete/status a performance, they cannot edit the core details
                        request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'updatedAt', 'performanceStartedAt', 'completedAt', 'actualAmount', 'paymentMethod', 'scheduledDate'])
                      ));
        allow create, delete: if isAdmin();
      }
    }

    // ─── Global Collection Group for Stops ───
    match /{path=**}/stops/{stopId} {
      allow read: if isSignedIn();
    }
  }
}
